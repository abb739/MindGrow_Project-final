<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="750.0" prefWidth="1100.0" spacing="0.0" styleClass="content-area" stylesheets="@global.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.Backoffice.SeanceController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" styleClass="header-section">
         <children>
            <VBox alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Label text="Gestion des Séances" styleClass="header-title" />
                  <Label text="Planifiez vos sessions et gérez les réservations clients." styleClass="header-subtitle" />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="10.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleClearForm" styleClass="btn-primary" text="+ Nouvelle Séance" />
                  <Button onAction="#handleManageReservations" styleClass="btn-outline" text="🎟 Réservations" />
                  <Button onAction="#handleExportCSV" styleClass="btn-outline" text="📩 Export CSV" />
               </children>
            </HBox>
         </children>
      </HBox>
      
      <HBox spacing="30.0" VBox.vgrow="ALWAYS" style="-fx-padding: 30;">
         <children>
            <!-- Formulaire modernisé -->
            <ScrollPane fitToWidth="true" maxWidth="410.0" minWidth="410.0" styleClass="form-scroll-pane" hbarPolicy="NEVER" HBox.hgrow="NEVER">
               <content>
                  <VBox spacing="20.0" styleClass="card">
                     <children>
                        <Label text="Détails de la Séance" styleClass="section-title" />
                        
                        <VBox spacing="8.0">
                           <Label text="TITRE" styleClass="label" />
                           <TextField fx:id="titreField" promptText="Ex: Séance de Méditation" />
                        </VBox>
                        <VBox spacing="8.0">
                           <Label text="IMAGE" styleClass="label" />
                           <HBox spacing="12.0" alignment="CENTER_LEFT">
                              <TextField fx:id="imageField" HBox.hgrow="ALWAYS" editable="false" promptText="Lien de l'image..." />
                              <Button onAction="#handleChooseImage" styleClass="btn-primary" text="Parcourir" />
                           </HBox>
                           <ImageView fx:id="imagePreview" fitHeight="60.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
                        </VBox>
                        
                        <VBox spacing="8.0">
                           <Label text="LIEU" styleClass="label" />
                           <HBox spacing="8.0" alignment="CENTER_LEFT">
                              <TextField fx:id="lieuField" promptText="Adresse ou salle..." HBox.hgrow="ALWAYS" />
                              <Button onAction="#handleOpenMap" styleClass="btn-outline" text="📍" />
                           </HBox>
                        </VBox>
                        
                        <HBox spacing="15.0">
                           <children>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <Label text="CAPACITÉ" styleClass="label" />
                                 <TextField fx:id="capaciteField" promptText="Max participants" />
                              </VBox>
                           </children>
                        </HBox>
                        
                        <VBox spacing="8.0">
                           <Label text="DATE ET HEURE DE DÉBUT" styleClass="label" />
                           <HBox spacing="8.0" alignment="CENTER_LEFT">
                              <DatePicker fx:id="dateDebutPicker" prefHeight="45.0" />
                              <Button onAction="#handlePickTimeDebut" styleClass="btn-outline" text="🕒" />
                              <Label fx:id="heureDebutLabel" text="00:00" style="-fx-font-weight: bold; -fx-text-fill: -fx-primary;" />
                           </HBox>
                        </VBox>
                        
                        <VBox spacing="8.0">
                           <Label text="DATE ET HEURE DE FIN" styleClass="label" />
                           <HBox spacing="8.0" alignment="CENTER_LEFT">
                              <DatePicker fx:id="dateFinPicker" prefHeight="45.0" />
                              <Button onAction="#handlePickTimeFin" styleClass="btn-outline" text="🕒" />
                              <Label fx:id="heureFinLabel" text="00:00" style="-fx-font-weight: bold; -fx-text-fill: -fx-primary;" />
                           </HBox>
                        </VBox>
                        
                        <VBox spacing="8.0">
                           <Label text="DESCRIPTION" styleClass="label" />
                           <TextArea fx:id="descriptionArea" prefHeight="80.0" promptText="Détails de la séance..." wrapText="true" />
                        </VBox>
                        
                        <HBox spacing="12.0" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                           <children>
                              <Button fx:id="saveBtn" mnemonicParsing="false" onAction="#handleSaveSeance" prefWidth="200.0" styleClass="btn-primary" text="Ajouter Séance" />
                              <Button mnemonicParsing="false" onAction="#handleClearForm" prefWidth="100.0" styleClass="btn-secondary" text="Vider" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
            
            <!-- Cards View modernisée -->
            <VBox HBox.hgrow="ALWAYS" spacing="20.0">
               <children>
                  <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 15 25;">
                     <children>
                        <Label text="Trier par :" styleClass="label" style="-fx-font-weight: bold;" />
                        <Button onAction="#handleSortDateASC" styleClass="btn-outline" text="Date ↑" />
                        <Button onAction="#handleSortDateDESC" styleClass="btn-outline" text="Date ↓" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="Affichage des séances planifiées" styleClass="header-subtitle" />
                     </children>
                  </HBox>
                  <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                     <content>
                        <FlowPane fx:id="cardsContainer" hgap="25.0" vgap="25.0" style="-fx-padding: 10; -fx-background-color: transparent;" />
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
