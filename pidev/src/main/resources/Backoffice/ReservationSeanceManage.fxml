<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="750.0" prefWidth="1100.0" spacing="0.0" styleClass="content-area" stylesheets="@global.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.Backoffice.ReservationSeanceManageController">
    <children>
        <!-- Header Section -->
        <HBox alignment="CENTER_LEFT" prefHeight="100.0" styleClass="header-section">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label text="Réservations de Séances" styleClass="header-title" />
                        <Label text="Gérez les inscriptions des participants aux sessions." styleClass="header-subtitle" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#loadReservations" styleClass="btn-outline" text="🔄 Actualiser" />
            </children>
        </HBox>

        <VBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 30;">
            <children>
                <TableView fx:id="reservationTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                        <TableColumn fx:id="colSeance" prefWidth="250" text="Séance" />
                        <TableColumn fx:id="colUtilisateur" prefWidth="250" text="Utilisateur" />
                        <TableColumn fx:id="colDate" prefWidth="150" text="Date Réservation" />
                        <TableColumn fx:id="colStatut" prefWidth="120" text="Statut" />
                        <TableColumn fx:id="colActions" prefWidth="150" text="Actions" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
