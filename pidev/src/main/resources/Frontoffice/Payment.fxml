<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="550.0" prefWidth="450.0" spacing="25.0" styleClass="auth-container" stylesheets="@front.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.Frontoffice.PaymentController">
   <children>
      <VBox alignment="CENTER" spacing="25.0" styleClass="auth-card" maxWidth="400.0">
         <children>
            <Label text="Paiement Sécurisé" styleClass="auth-title" />
            
            <Label fx:id="amountLabel" text="Montant à régler : 0.00 TND" styleClass="payment-amount" />
      
            <Separator prefWidth="300.0" />
      
            <VBox spacing="8.0">
               <children>
                  <Label text="NOM SUR LA CARTE" styleClass="payment-label" />
                  <TextField fx:id="cardHolderField" prefHeight="45.0" promptText="Ex: Flen Ben Flen" styleClass="auth-input" />
               </children>
            </VBox>
      
            <VBox spacing="8.0">
               <children>
                  <Label text="NUMÉRO DE CARTE" styleClass="payment-label" />
                  <TextField fx:id="cardNumberField" prefHeight="45.0" promptText="XXXX XXXX XXXX XXXX" styleClass="auth-input" />
               </children>
            </VBox>
      
            <HBox spacing="15.0">
               <children>
                  <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                     <children>
                        <Label text="EXPIRATION" styleClass="payment-label" />
                        <TextField fx:id="expiryField" prefHeight="45.0" promptText="MM/YY" styleClass="auth-input" />
                     </children>
                  </VBox>
                  <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                     <children>
                        <Label text="CVC" styleClass="payment-label" />
                        <TextField fx:id="cvcField" prefHeight="45.0" promptText="123" styleClass="auth-input" />
                     </children>
                  </VBox>
               </children>
            </HBox>
      
            <VBox spacing="10.0" alignment="CENTER">
               <children>
                  <Button fx:id="payButton" onAction="#handlePayment" prefHeight="50.0" prefWidth="Infinity" styleClass="btn-primary-modern" text="Confirmer le Paiement" />
                  <Button onAction="#handleCancel" prefHeight="35.0" prefWidth="Infinity" styleClass="auth-link" style="-fx-text-fill: #ef4444;" text="Annuler" />
               </children>
            </VBox>
            
            <Label fx:id="statusLabel" textAlignment="CENTER" wrapText="true" styleClass="profil-message" />
         </children>
      </VBox>
   </children>
</VBox>
