<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@front.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.Frontoffice.ProgrammeFrontController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="1100.0" spacing="30.0" styleClass="front-container">
         <children>
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label text="Nos Programmes" styleClass="auth-title" />
                  <Label text="Explorez nos parcours de développement personnel pour votre bien-être." styleClass="front-header-subtitle" />
               </children>
            </VBox>
      
            <!-- Barre de recherche et filtres modernisée -->
            <HBox alignment="CENTER" spacing="20.0" styleClass="front-filter-bar">
               <children>
                  <TextField fx:id="searchField" prefHeight="45.0" prefWidth="400.0" promptText="🔍 Rechercher un programme..." styleClass="front-search-field-small" />
                  <ComboBox fx:id="catFilterCombo" prefHeight="45.0" prefWidth="250.0" promptText="Toutes les catégories" styleClass="front-combo-box" />
                  <Button fx:id="youtubeSearchBtn" mnemonicParsing="false" onAction="#handleYoutubeSearch" styleClass="btn-youtube" text="YouTube 📺" />
                  <Button mnemonicParsing="false" onAction="#handleOpenTimer" styleClass="btn-timer" text="Minuteur ⏱️" />
               </children>
            </HBox>
            
            <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="front-scroll-pane" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="progCardsContainer" alignment="CENTER" hgap="30.0" styleClass="front-cards-container" vgap="30.0" />
               </content>
            </ScrollPane>
      
            <!-- Pagination modernisée -->
            <HBox alignment="CENTER" spacing="30.0">
               <children>
                  <Button fx:id="prevBtn" mnemonicParsing="false" onAction="#handlePrevPage" styleClass="btn-outline-modern" text="← Précédent" />
                  <Label fx:id="pageLabel" text="Page 1 / 1" style="-fx-font-weight: bold; -fx-text-fill: -fx-secondary; -fx-font-size: 15px;" />
                  <Button fx:id="nextBtn" mnemonicParsing="false" onAction="#handleNextPage" styleClass="btn-outline-modern" text="Suivant →" />
               </children>
               <padding>
                  <Insets bottom="20.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
      <Button mnemonicParsing="false" onAction="#handleOpenChatbot" styleClass="btn-chatbot" text="💬 Assistant IA" StackPane.alignment="BOTTOM_RIGHT">
         <StackPane.margin>
            <Insets bottom="40.0" right="40.0" />
         </StackPane.margin>
      </Button>
   </children>
</StackPane>
