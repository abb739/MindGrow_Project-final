<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="1100.0" spacing="0.0" styleClass="front-container" 
      stylesheets="@front.css" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="org.example.controller.Frontoffice.TherapeuteFrontController">
   <children>
      <!-- Header section modernisé -->
      <VBox alignment="CENTER" styleClass="front-header">
         <children>
            <Label text="Nos Thérapeutes" styleClass="auth-title" />
            <Label text="Un accompagnement bienveillant pour votre équilibre et votre sérénité." styleClass="front-header-subtitle">
               <VBox.margin><Insets top="10.0" /></VBox.margin>
            </Label>
  
            <!-- Barre de recherche moderne -->
            <HBox alignment="CENTER" spacing="10.0">
               <VBox.margin><Insets top="30.0" /></VBox.margin>
               <children>
                  <TextField fx:id="searchField" prefHeight="50.0" prefWidth="550.0" 
                              promptText="🔍 Rechercher un nom ou une spécialité..." 
                              styleClass="front-search-field" />
               </children>
            </HBox>
         </children>
      </VBox>

      <!-- Filter speciality chips container -->
      <HBox fx:id="specialityFilters" alignment="CENTER" spacing="15.0" styleClass="filter-container">
         <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
      </HBox>

      <!-- Cards -->
      <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="front-scroll-pane">
         <content>
            <FlowPane fx:id="cardsContainer" alignment="CENTER" hgap="30.0" vgap="30.0" styleClass="front-cards-container" />
         </content>
      </ScrollPane>
   </children>
</VBox>
