<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="450.0" spacing="0.0" styleClass="chat-container" stylesheets="@front.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.Frontoffice.ChatbotController">
   <children>
      <HBox alignment="CENTER" prefHeight="65.0" styleClass="chat-header">
         <children>
            <Label text="🤖 Assistant IA MindGrow" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 18px;" />
         </children>
      </HBox>
      <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="cards-scroll" style="-fx-background-color: #f8fafc;">
         <content>
            <VBox fx:id="chatBox" spacing="15.0" style="-fx-padding: 20;" />
         </content>
      </ScrollPane>
      <HBox alignment="CENTER" spacing="12.0" style="-fx-padding: 20; -fx-background-color: white;">
         <children>
            <TextField fx:id="messageInput" onAction="#handleSendMessage" HBox.hgrow="ALWAYS" prefHeight="45.0" promptText="Tapez votre message ici..." styleClass="auth-input" />
            <Button mnemonicParsing="false" onAction="#handleSendMessage" prefHeight="45.0" prefWidth="80.0" styleClass="btn-primary-modern" text="Envoyer" />
         </children>
      </HBox>
   </children>
</VBox>
