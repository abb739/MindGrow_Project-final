<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" prefHeight="550.0" prefWidth="500.0" styleClass="auth-container" stylesheets="@front.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.Frontoffice.ForgotPasswordController">
   <children>
      <VBox alignment="CENTER" prefWidth="400.0" spacing="20.0" styleClass="auth-card" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="40.0" AnchorPane.bottomAnchor="40.0">
         <children>
            <Label text="Mot de passe oublié ?" styleClass="auth-title" />
            
            <Label text="Saisissez votre e-mail pour réinitialiser le mot de passe." styleClass="profil-label" wrapText="true" textAlignment="CENTER">
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </Label>
            
            <VBox spacing="15.0" maxWidth="320.0">
               <children>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="Nom" styleClass="profil-label" />
                        <TextField fx:id="nomField" prefHeight="45.0" promptText="Votre nom" styleClass="auth-input" />
                     </children>
                  </VBox>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="E-mail" styleClass="profil-label" />
                        <TextField fx:id="emailField" prefHeight="45.0" promptText="exemple@email.com" styleClass="auth-input" />
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <Label fx:id="errorMessage" styleClass="profil-message" style="-fx-text-fill: #ef4444;" wrapText="true" textAlignment="CENTER" />
            
            <Button mnemonicParsing="false" onAction="#handleResetPassword" prefHeight="45.0" prefWidth="320.0" styleClass="btn-primary-modern" text="Réinitialiser le mot de passe" />
            
            <Button mnemonicParsing="false" onAction="#backToLogin" styleClass="auth-link" text="Retour à la connexion" />
         </children>
      </VBox>
   </children>
</AnchorPane>
