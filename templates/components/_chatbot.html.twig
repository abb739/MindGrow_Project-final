{# ════════════════════════════════════════════════════════════════════
   CHATBOT IA — Composant flottant à inclure dans base.html.twig
   
   USAGE : Ajoutez {{ include('components/_chatbot.html.twig') }}
           juste avant </body> dans votre base.html.twig
   ════════════════════════════════════════════════════════════════════ #}

<style>
/* ─── Bouton flottant ─── */
#chatbot-toggle {
  position: fixed; bottom: 28px; right: 28px; z-index: 9999;
  width: 60px; height: 60px; border-radius: 50%; border: none; cursor: pointer;
  background: linear-gradient(135deg, #0b7a8f, #065f6e);
  box-shadow: 0 8px 32px rgba(11,122,143,.45);
  font-size: 26px; color: white;
  transition: transform .2s, box-shadow .2s;
}
#chatbot-toggle:hover { transform: scale(1.1); box-shadow: 0 12px 40px rgba(11,122,143,.6); }

/* ─── Fenêtre chat ─── */
#chatbot-window {
  position: fixed; bottom: 100px; right: 28px; z-index: 9998;
  width: 370px; max-height: 540px;
  background: white; border-radius: 20px;
  box-shadow: 0 20px 60px rgba(0,0,0,.18);
  display: none; flex-direction: column; overflow: hidden;
  border: 1px solid #e2e8f0;
}
#chatbot-window.open { display: flex; }

/* ─── Header ─── */
.cb-header {
  background: linear-gradient(135deg, #0b7a8f, #065f6e);
  color: white; padding: 16px 18px;
  display: flex; align-items: center; gap: 10px;
}
.cb-header .cb-avatar { font-size: 22px; }
.cb-header .cb-info h4 { margin: 0; font-size: 15px; font-weight: 700; }
.cb-header .cb-info p  { margin: 0; font-size: 11px; opacity: .8; }
.cb-mode-btns { display: flex; gap: 6px; padding: 10px 14px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; flex-wrap: wrap; }
.cb-mode-btn {
  padding: 4px 12px; border-radius: 20px; border: 2px solid #0b7a8f;
  background: white; color: #0b7a8f; font-size: 11px; font-weight: 600; cursor: pointer;
  transition: all .15s;
}
.cb-mode-btn.active, .cb-mode-btn:hover { background: #0b7a8f; color: white; }

/* ─── Messages ─── */
#cb-messages {
  flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px;
  max-height: 300px;
}
.cb-msg { max-width: 82%; padding: 10px 14px; border-radius: 16px; font-size: 13px; line-height: 1.5; }
.cb-msg.bot  { background: #f1f5f9; color: #1e293b; align-self: flex-start; border-radius: 4px 16px 16px 16px; }
.cb-msg.user { background: #0b7a8f; color: white; align-self: flex-end; border-radius: 16px 4px 16px 16px; }
.cb-msg.typing { background: #f1f5f9; align-self: flex-start; }
.cb-dots span { display: inline-block; width: 7px; height: 7px; margin: 0 2px;
  background: #94a3b8; border-radius: 50%; animation: bounce .9s infinite; }
.cb-dots span:nth-child(2) { animation-delay: .15s; }
.cb-dots span:nth-child(3) { animation-delay: .3s; }
@keyframes bounce { 0%,80%,100%{transform:translateY(0)} 40%{transform:translateY(-6px)} }

/* ─── Input ─── */
.cb-input-row {
  display: flex; gap: 8px; padding: 12px 14px; border-top: 1px solid #e2e8f0; background: white;
}
#cb-input {
  flex: 1; border: 1.5px solid #e2e8f0; border-radius: 12px;
  padding: 8px 12px; font-size: 13px; outline: none;
  transition: border-color .2s;
}
#cb-input:focus { border-color: #0b7a8f; }
#cb-send {
  padding: 8px 16px; border-radius: 12px; border: none;
  background: #0b7a8f; color: white; font-size: 13px; font-weight: 600;
  cursor: pointer; transition: background .2s;
}
#cb-send:hover { background: #065f6e; }
</style>

{# Bouton flottant #}
<button id="chatbot-toggle" title="Assistant IA MindGrow">🤖</button>

{# Fenêtre #}
<div id="chatbot-window">
  <div class="cb-header">
    <div class="cb-avatar">🌱</div>
    <div class="cb-info">
      <h4>Assistant MindGrow</h4>
      <p>IA • Répond en quelques secondes</p>
    </div>
  </div>

  <div class="cb-mode-btns">
    <button class="cb-mode-btn active" data-mode="general">💬 Général</button>
    <button class="cb-mode-btn" data-mode="therapeute">🧑‍⚕️ Thérapeute</button>
    <button class="cb-mode-btn" data-mode="seance">🧘 Séance</button>
    <button class="cb-mode-btn" data-mode="abonnement">💳 Abonnement</button>
  </div>

  <div id="cb-messages">
    <div class="cb-msg bot">Bonjour ! Je suis l'assistant IA de MindGrow. Comment puis-je vous aider ? 😊</div>
  </div>

  <div class="cb-input-row">
    <input id="cb-input" type="text" placeholder="Écrivez votre message…" autocomplete="off">
    <button id="cb-send">Envoyer</button>
  </div>
</div>

<script>
(function () {
  const toggle   = document.getElementById('chatbot-toggle');
  const win      = document.getElementById('chatbot-window');
  const messages = document.getElementById('cb-messages');
  const input    = document.getElementById('cb-input');
  const sendBtn  = document.getElementById('cb-send');
  const modeBtns = document.querySelectorAll('.cb-mode-btn');

  // Routes par mode
  const ROUTES = {
    general:     '/chatbot/message',
    therapeute:  '/chatbot/recommander-therapeute',
    seance:      '/chatbot/recommander-seance',
    abonnement:  '/chatbot/abonnement',
  };
  const PLACEHOLDERS = {
    general:     'Posez n\'importe quelle question…',
    therapeute:  'Ex: Je me sens stressé, anxieux…',
    seance:      'Ex: Je veux travailler ma respiration…',
    abonnement:  'Ex: Quel abonnement me convient ?',
  };
  let currentMode = 'general';

  // Toggle fenêtre
  toggle.addEventListener('click', () => win.classList.toggle('open'));

  // Changement de mode
  modeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      modeBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentMode = btn.dataset.mode;
      input.placeholder = PLACEHOLDERS[currentMode];
    });
  });

  // Envoi
  function send() {
    const text = input.value.trim();
    if (!text) return;
    addMsg(text, 'user');
    input.value = '';
    const typingEl = addTyping();

    fetch(ROUTES[currentMode], {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ message: text }),
    })
    .then(r => r.json())
    .then(data => {
      typingEl.remove();
      addMsg(data.response || data.error || 'Erreur.', 'bot');
    })
    .catch(() => { typingEl.remove(); addMsg('Erreur de connexion.', 'bot'); });
  }

  sendBtn.addEventListener('click', send);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') send(); });

  function addMsg(text, who) {
    const div = document.createElement('div');
    div.className = 'cb-msg ' + who;
    div.textContent = text;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
    return div;
  }

  function addTyping() {
    const div = document.createElement('div');
    div.className = 'cb-msg typing';
    div.innerHTML = '<div class="cb-dots"><span></span><span></span><span></span></div>';
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
    return div;
  }
})();
</script>
