{% extends 'admin/base2.html.twig' %}
{% block title %}Statistiques Abonnements{% endblock %}
{% block body %}

<style>
.stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px; margin-bottom:32px; }
.kpi-card { background:var(--bg2); border-radius:16px; padding:20px 24px; box-shadow:var(--shadow-sm); border:1px solid var(--border2); }
.kpi-val  { font-size:32px; font-weight:800; color:#0b7a8f; }
.kpi-lbl  { font-size:13px; color:var(--text2); margin-top:4px; }
.kpi-delta { font-size:12px; margin-top:6px; font-weight:600; }
.kpi-delta.up   { color:#10b981; }
.kpi-delta.down { color:#ef4444; }

.charts-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px; }
@media(max-width:768px){ .charts-grid { grid-template-columns:1fr; } }

.chart-card { background:var(--bg2); border-radius:16px; padding:24px; box-shadow:var(--shadow-sm); border:1px solid var(--border2); }
.chart-card h3 { font-size:15px; font-weight:700; color:var(--text); margin-bottom:16px; display:flex; align-items:center; gap:8px; }
.chart-full { grid-column: 1 / -1; }
.chart-wrap { position:relative; height:260px; }
.chart-wrap-sm { position:relative; height:220px; }

.loading { text-align:center; padding:40px; color:var(--text2); font-size:14px; }
</style>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px;">
    <div>
        <h1 style="font-size:26px;font-weight:800;color:var(--text);">📊 Statistiques Abonnements</h1>
        <p style="color:var(--text2);font-size:14px;margin-top:4px;">Tableau de bord analytique en temps réel</p>
    </div>
    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
        <button onclick="exporterPDF()" id="btn-pdf"
            style="display:flex; align-items:center; gap:8px; padding:10px 20px;
                   background:linear-gradient(135deg,#ef4444,#dc2626); color:white;
                   border:none; border-radius:12px; font-size:14px; font-weight:700;
                   cursor:pointer; box-shadow:0 4px 15px rgba(239,68,68,.35);
                   transition:all .2s;">
            <span id="pdf-icon">📄</span>
            <span id="pdf-label">Exporter PDF</span>
        </button>
        <a href="{{ path('admin_abonnements') }}" class="btn" style="background:var(--bg3);color:var(--text2);">
            ← Gestion abonnements
        </a>
    </div>
</div>

{# ── KPIs ── #}
<div class="stats-grid" id="kpi-grid">
    <div class="kpi-card"><div class="kpi-val" id="kpi-total">—</div><div class="kpi-lbl">Souscriptions totales</div></div>
    <div class="kpi-card"><div class="kpi-val" id="kpi-actifs">—</div><div class="kpi-lbl">Abonnés actifs</div></div>
    <div class="kpi-card"><div class="kpi-val" id="kpi-revenu">—</div><div class="kpi-lbl">Revenus totaux (TND)</div></div>
    <div class="kpi-card"><div class="kpi-val" id="kpi-taux">—</div><div class="kpi-lbl">Taux de rétention</div></div>
</div>

{# ── Charts ── #}
<div class="charts-grid">

    {# Revenus mensuels — full width #}
    <div class="chart-card chart-full">
        <h3>📈 Revenus & souscriptions mensuels</h3>
        <div class="chart-wrap"><canvas id="chartRevenus"></canvas></div>
    </div>

    {# Répartition par plan #}
    <div class="chart-card">
        <h3>🥧 Répartition par plan</h3>
        <div class="chart-wrap-sm"><canvas id="chartPlans"></canvas></div>
    </div>

    {# Statuts #}
    <div class="chart-card">
        <h3>📋 Statuts des achats</h3>
        <div class="chart-wrap-sm"><canvas id="chartStatuts"></canvas></div>
    </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const TEAL   = '#0b7a8f';
const TEAL2  = '#065f6e';
const GREEN  = '#10b981';
const AMBER  = '#f59e0b';
const RED    = '#ef4444';
const PURPLE = '#8b5cf6';
const BLUE   = '#3b82f6';

const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
Chart.defaults.color = isDark ? '#94a3b8' : '#64748b';
Chart.defaults.borderColor = isDark ? '#334155' : '#f1f5f9';

// ── 1. Revenus mensuels ──
fetch('/api/stats/revenus-mensuels')
.then(r => r.json())
.then(data => {
    if (!data.labels?.length) {
        document.getElementById('chartRevenus').closest('.chart-card').innerHTML += 
            '<div class="loading">Aucune donnée disponible</div>';
        return;
    }
    new Chart(document.getElementById('chartRevenus'), {
        type: 'bar',
        data: {
            labels: data.labels,
            datasets: [
                {
                    label: 'Revenus (TND)',
                    data: data.revenus,
                    backgroundColor: TEAL + 'cc',
                    borderColor: TEAL,
                    borderWidth: 2,
                    borderRadius: 8,
                    yAxisID: 'y',
                },
                {
                    label: 'Souscriptions',
                    data: data.achats,
                    type: 'line',
                    borderColor: GREEN,
                    backgroundColor: GREEN + '22',
                    borderWidth: 2.5,
                    pointRadius: 5,
                    pointBackgroundColor: GREEN,
                    fill: true,
                    tension: 0.4,
                    yAxisID: 'y2',
                }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'top' } },
            scales: {
                y:  { beginAtZero: true, position: 'left',  title: { display: true, text: 'TND' } },
                y2: { beginAtZero: true, position: 'right', title: { display: true, text: 'Nb' }, grid: { drawOnChartArea: false } }
            }
        }
    });

    // KPIs from monthly data
    const totalRevenu = data.revenus.reduce((a,b)=>a+b, 0);
    const totalAchats = data.achats.reduce((a,b)=>a+b, 0);
    document.getElementById('kpi-total').textContent  = totalAchats;
    document.getElementById('kpi-revenu').textContent = totalRevenu.toFixed(0) + ' TND';
});

// ── 2. Répartition par plan ──
fetch('/api/stats/repartition-plans')
.then(r => r.json())
.then(data => {
    if (!data.labels?.length) return;

    const colors = [TEAL, GREEN, AMBER, PURPLE, BLUE, RED];
    new Chart(document.getElementById('chartPlans'), {
        type: 'doughnut',
        data: {
            labels: data.labels,
            datasets: [{
                data: data.actifs,
                backgroundColor: colors.slice(0, data.labels.length).map(c => c + 'cc'),
                borderColor: colors.slice(0, data.labels.length),
                borderWidth: 2,
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { padding: 12, font: { size: 12 } } },
                tooltip: {
                    callbacks: {
                        label: ctx => ` ${ctx.label}: ${ctx.parsed} actifs`
                    }
                }
            },
            cutout: '62%',
        }
    });

    const totalActifs = data.actifs.reduce((a,b)=>a+b,0);
    const totalAll    = data.actifs.reduce((a,b)=>a+b,0);
    document.getElementById('kpi-actifs').textContent = totalActifs;
    document.getElementById('kpi-taux').textContent   = totalAll > 0
        ? Math.round(totalActifs / totalAll * 100) + '%'
        : '—';
});

// ── 3. Statuts ──
fetch('/api/stats/statuts')
.then(r => r.json())
.then(data => {
    if (!data.labels?.length) return;

    const colorMap = { actif: GREEN, 'annulé': RED, expiré: AMBER };
    const bg = data.labels.map(l => (colorMap[l] || TEAL) + 'cc');
    const bd = data.labels.map(l => colorMap[l] || TEAL);

    new Chart(document.getElementById('chartStatuts'), {
        type: 'pie',
        data: {
            labels: data.labels,
            datasets: [{ data: data.values, backgroundColor: bg, borderColor: bd, borderWidth: 2 }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom', labels: { padding: 12, font: { size: 12 } } } }
        }
    });
});

// Réappliquer si thème change
document.getElementById('themeToggle')?.addEventListener('click', () => location.reload());

// ── Export PDF Amélioré ─────────────────────────────────────────
async function exporterPDF() {
    const btn   = document.getElementById('btn-pdf');
    const label = document.getElementById('pdf-label');
    const icon  = document.getElementById('pdf-icon');

    btn.disabled      = true;
    icon.textContent  = '⏳';
    label.textContent = 'Génération...';

    try {
        if (!window.html2canvas) {
            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js');
        }
        if (!window.jspdf) {
            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');
        }

        const { jsPDF } = window.jspdf;
        const pdf    = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
        const pageW  = 210;
        const pageH  = 297;
        const margin = 14;
        const teal   = [11, 122, 143];

        // ── Helper : ajouter section titre ──
        function sectionTitre(texte, posY) {
            pdf.setFontSize(12);
            pdf.setFont('helvetica', 'bold');
            pdf.setTextColor(...teal);
            pdf.text(texte, margin, posY);
            pdf.setDrawColor(...teal);
            pdf.setLineWidth(0.4);
            pdf.line(margin, posY + 1.5, pageW - margin, posY + 1.5);
            pdf.setTextColor(0, 0, 0);
        }

        // ── PAGE 1 : En-tête ──
        // Bande de couleur
        pdf.setFillColor(...teal);
        pdf.rect(0, 0, pageW, 30, 'F');

        // Titre sans emoji (évite le problème d'encodage)
        pdf.setTextColor(255, 255, 255);
        pdf.setFontSize(17);
        pdf.setFont('helvetica', 'bold');
        pdf.text('Statistiques Abonnements - MindGrow', margin, 13);

        pdf.setFontSize(9);
        pdf.setFont('helvetica', 'normal');
        const now = new Date().toLocaleDateString('fr-FR', {
            day: '2-digit', month: 'long', year: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });
        pdf.text('Genere le : ' + now, margin, 22);
        pdf.text('Rapport confidentiel — MindGrow', pageW - margin, 22, { align: 'right' });
        pdf.setTextColor(0, 0, 0);

        let y = 38;

        // ── KPIs ──
        sectionTitre('Indicateurs cles', y);
        y += 7;

        const kpis = [
            { id: 'kpi-total',  label: 'Souscriptions totales', icon: '>>>' },
            { id: 'kpi-actifs', label: 'Abonnes actifs',        icon: '***' },
            { id: 'kpi-revenu', label: 'Revenus totaux',        icon: 'TND' },
            { id: 'kpi-taux',   label: 'Taux de retention',     icon: '%%%' },
        ];

        const kpiW = (pageW - margin * 2 - 6) / 4;
        kpis.forEach((k, i) => {
            const x   = margin + i * (kpiW + 2);
            const val = document.getElementById(k.id)?.textContent?.trim() || '—';

            // Fond coloré
            pdf.setFillColor(236, 254, 255);
            pdf.roundedRect(x, y, kpiW, 22, 3, 3, 'F');
            pdf.setDrawColor(...teal);
            pdf.setLineWidth(0.5);
            pdf.roundedRect(x, y, kpiW, 22, 3, 3, 'S');

            // Valeur
            pdf.setFontSize(15);
            pdf.setFont('helvetica', 'bold');
            pdf.setTextColor(...teal);
            pdf.text(val, x + kpiW / 2, y + 10, { align: 'center', maxWidth: kpiW - 2 });

            // Label
            pdf.setFontSize(7.5);
            pdf.setFont('helvetica', 'normal');
            pdf.setTextColor(71, 85, 105);
            pdf.text(k.label, x + kpiW / 2, y + 17, { align: 'center' });
        });
        y += 30;

        // ── Capture graphique revenus (pleine largeur) ──
        sectionTitre('Revenus & Souscriptions mensuels', y);
        y += 6;

        const canvasRevenus = document.getElementById('chartRevenus');
        if (canvasRevenus) {
            const imgRev = await html2canvas(canvasRevenus.closest('.chart-card'), {
                backgroundColor: '#0f172a',
                scale: 2,
                useCORS: true,
                logging: false,
            });
            const revW = pageW - margin * 2;
            const revH = Math.round((imgRev.height * revW) / imgRev.width);
            const revHClamped = Math.min(revH, 72);

            // Saut de page si nécessaire
            if (y + revHClamped > pageH - 15) { pdf.addPage(); y = 15; }

            pdf.addImage(imgRev.toDataURL('image/jpeg', 0.95), 'JPEG', margin, y, revW, revHClamped);
            // Bordure
            pdf.setDrawColor(200, 220, 230);
            pdf.setLineWidth(0.3);
            pdf.rect(margin, y, revW, revHClamped, 'S');
            y += revHClamped + 10;
        }

        // ── Capture graphiques côte à côte ──
        sectionTitre('Repartition & Statuts', y);
        y += 6;

        const colW   = (pageW - margin * 2 - 8) / 2;
        const charts2 = [
            { id: 'chartPlans',   titre: 'Repartition par plan' },
            { id: 'chartStatuts', titre: 'Statuts des achats'   },
        ];

        let maxSmH = 0;
        const smImages = [];

        for (const ch of charts2) {
            const canvas = document.getElementById(ch.id);
            if (!canvas) { smImages.push(null); continue; }

            const img = await html2canvas(canvas.closest('.chart-card'), {
                backgroundColor: '#0f172a',
                scale: 2,
                useCORS: true,
                logging: false,
            });
            const imgH = Math.min(Math.round((img.height * colW) / img.width), 75);
            maxSmH = Math.max(maxSmH, imgH);
            smImages.push({ data: img, w: colW, h: imgH, titre: ch.titre });
        }

        // Saut de page si nécessaire
        if (y + maxSmH + 10 > pageH - 15) { pdf.addPage(); y = 15; }

        smImages.forEach((sm, i) => {
            if (!sm) return;
            const x = margin + i * (colW + 8);

            // Sous-titre de graphique
            pdf.setFontSize(9);
            pdf.setFont('helvetica', 'bold');
            pdf.setTextColor(30, 41, 59);
            pdf.text(sm.titre, x + colW / 2, y - 1, { align: 'center' });

            pdf.addImage(sm.data.toDataURL('image/jpeg', 0.95), 'JPEG', x, y, sm.w, sm.h);
            pdf.setDrawColor(200, 220, 230);
            pdf.setLineWidth(0.3);
            pdf.rect(x, y, sm.w, sm.h, 'S');
        });
        y += maxSmH + 12;

        // ── Pied de page sur toutes les pages ──
        const totalPages = pdf.internal.getNumberOfPages();
        for (let p = 1; p <= totalPages; p++) {
            pdf.setPage(p);
            pdf.setFillColor(245, 250, 252);
            pdf.rect(0, pageH - 12, pageW, 12, 'F');
            pdf.setDrawColor(...teal);
            pdf.setLineWidth(0.3);
            pdf.line(0, pageH - 12, pageW, pageH - 12);
            pdf.setFontSize(8);
            pdf.setFont('helvetica', 'normal');
            pdf.setTextColor(100, 116, 139);
            pdf.text('MindGrow — Rapport Statistiques Abonnements', margin, pageH - 5);
            pdf.text('Page ' + p + ' / ' + totalPages, pageW - margin, pageH - 5, { align: 'right' });
        }

        // ── Téléchargement ──
        const dateStr = new Date().toISOString().slice(0, 10);
        pdf.save('stats_mindgrow_' + dateStr + '.pdf');

    } catch(e) {
        console.error('[PDF] Erreur:', e);
        alert('Erreur lors de la generation du PDF : ' + e.message);
    } finally {
        btn.disabled      = false;
        icon.textContent  = '📄';
        label.textContent = 'Exporter PDF';
    }
}

function loadScript(src) {
    return new Promise((resolve, reject) => {
        const s = document.createElement('script');
        s.src = src; s.onload = resolve; s.onerror = reject;
        document.head.appendChild(s);
    });
}
</script>

{% endblock %}
