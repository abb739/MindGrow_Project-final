{% extends 'admin/base2.html.twig' %}
{% block title %}Statistiques Programmes{% endblock %}
{% block body %}

<style>
.stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px; margin-bottom:32px; }
.kpi-card { background:var(--bg2); border-radius:16px; padding:20px 24px; box-shadow:var(--shadow-sm); border:1px solid var(--border2); }
.kpi-val  { font-size:32px; font-weight:800; color:#0b7a8f; }
.kpi-lbl  { font-size:13px; color:var(--text2); margin-top:4px; }

.charts-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px; }
@media(max-width:768px){ .charts-grid { grid-template-columns:1fr; } }

.chart-card { background:var(--bg2); border-radius:16px; padding:24px; box-shadow:var(--shadow-sm); border:1px solid var(--border2); }
.chart-card h3 { font-size:15px; font-weight:700; color:var(--text); margin-bottom:16px; display:flex; align-items:center; gap:8px; }
.chart-full { grid-column: 1 / -1; }
.chart-wrap { position:relative; height:280px; }
.chart-wrap-sm { position:relative; height:220px; }
.loading { text-align:center; padding:40px; color:var(--text2); font-size:14px; }
</style>

{# ── En-tête ── #}
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px;">
    <div>
        <h1 style="font-size:26px;font-weight:800;color:var(--text);">📊 Statistiques Programmes</h1>
        <p style="color:var(--text2);font-size:14px;margin-top:4px;">Tableau de bord analytique en temps réel</p>
    </div>
    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
        <button onclick="exporterPDF()" id="btn-pdf"
            style="display:flex; align-items:center; gap:8px; padding:10px 20px;
                   background:linear-gradient(135deg,#ef4444,#dc2626); color:white;
                   border:none; border-radius:12px; font-size:14px; font-weight:700;
                   cursor:pointer; box-shadow:0 4px 15px rgba(239,68,68,.35);
                   transition:all .2s;">
            <span id="pdf-icon">📄</span>
            <span id="pdf-label">Exporter PDF</span>
        </button>
        <a href="{{ path('admin_programmes') }}" class="btn" style="background:var(--bg3);color:var(--text2);">
            ← Gestion programmes
        </a>
    </div>
</div>

{# ── KPIs ── #}
<div class="stats-grid" id="kpi-grid">
    <div class="kpi-card"><div class="kpi-val" id="kpi-total">—</div><div class="kpi-lbl">Total programmes</div></div>
    <div class="kpi-card"><div class="kpi-val" id="kpi-cats">—</div><div class="kpi-lbl">Catégories actives</div></div>
    <div class="kpi-card"><div class="kpi-val" id="kpi-images">—</div><div class="kpi-lbl">Avec image</div></div>
    <div class="kpi-card"><div class="kpi-val" id="kpi-videos">—</div><div class="kpi-lbl">Avec vidéo</div></div>
</div>

{# ── Charts ── #}
<div class="charts-grid">

    {# Programmes par catégorie — full width bar chart #}
    <div class="chart-card chart-full">
        <h3>📂 Programmes par catégorie</h3>
        <div class="chart-wrap"><canvas id="chartCategories"></canvas></div>
    </div>

    {# Couverture images #}
    <div class="chart-card">
        <h3>🖼️ Couverture Images</h3>
        <div class="chart-wrap-sm"><canvas id="chartImages"></canvas></div>
    </div>

    {# Couverture vidéos #}
    <div class="chart-card">
        <h3>🎬 Couverture Vidéos</h3>
        <div class="chart-wrap-sm"><canvas id="chartVideos"></canvas></div>
    </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const TEAL   = '#0b7a8f';
const TEAL2  = '#065f6e';
const GREEN  = '#10b981';
const AMBER  = '#f59e0b';
const RED    = '#ef4444';
const PURPLE = '#8b5cf6';
const BLUE   = '#3b82f6';
const GRAY   = '#94a3b8';

const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
Chart.defaults.color = isDark ? '#94a3b8' : '#64748b';
Chart.defaults.borderColor = isDark ? '#334155' : '#f1f5f9';

const PALETTE = [TEAL, GREEN, AMBER, PURPLE, BLUE, RED, '#f97316', '#06b6d4'];

// ── 1. KPIs ──
fetch('/api/stats/programmes/kpis')
.then(r => r.json())
.then(data => {
    document.getElementById('kpi-total').textContent  = data.total_programmes ?? '—';
    document.getElementById('kpi-cats').textContent   = data.total_categories ?? '—';
    document.getElementById('kpi-images').textContent = data.avec_image ?? '—';
    document.getElementById('kpi-videos').textContent = data.avec_video ?? '—';
});

// ── 2. Programmes par catégorie ──
fetch('/api/stats/programmes/par-categorie')
.then(r => r.json())
.then(data => {
    if (!data.labels?.length) {
        document.getElementById('chartCategories').closest('.chart-card').innerHTML +=
            '<div class="loading">Aucune donnée disponible</div>';
        return;
    }
    new Chart(document.getElementById('chartCategories'), {
        type: 'bar',
        data: {
            labels: data.labels,
            datasets: [{
                label: 'Nb de programmes',
                data: data.values,
                backgroundColor: PALETTE.slice(0, data.labels.length).map(c => c + 'cc'),
                borderColor: PALETTE.slice(0, data.labels.length),
                borderWidth: 2,
                borderRadius: 8,
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 }, title: { display: true, text: 'Programmes' } },
                x: { title: { display: true, text: 'Catégorie' } }
            }
        }
    });
});

// ── 3 & 4. Couverture médias ──
fetch('/api/stats/programmes/medias')
.then(r => r.json())
.then(data => {

    // Chart Images
    new Chart(document.getElementById('chartImages'), {
        type: 'doughnut',
        data: {
            labels: ['Avec image', 'Sans image'],
            datasets: [{
                data: [data.avec_image, data.sans_image],
                backgroundColor: [GREEN + 'cc', GRAY + '66'],
                borderColor: [GREEN, GRAY],
                borderWidth: 2,
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { padding: 12, font: { size: 12 } } },
                tooltip: {
                    callbacks: {
                        label: ctx => {
                            const pct = data.total > 0 ? Math.round(ctx.parsed / data.total * 100) : 0;
                            return ` ${ctx.label}: ${ctx.parsed} (${pct}%)`;
                        }
                    }
                }
            },
            cutout: '62%',
        }
    });

    // Chart Vidéos
    new Chart(document.getElementById('chartVideos'), {
        type: 'doughnut',
        data: {
            labels: ['Avec vidéo', 'Sans vidéo'],
            datasets: [{
                data: [data.avec_video, data.sans_video],
                backgroundColor: [TEAL + 'cc', GRAY + '66'],
                borderColor: [TEAL, GRAY],
                borderWidth: 2,
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { padding: 12, font: { size: 12 } } },
                tooltip: {
                    callbacks: {
                        label: ctx => {
                            const pct = data.total > 0 ? Math.round(ctx.parsed / data.total * 100) : 0;
                            return ` ${ctx.label}: ${ctx.parsed} (${pct}%)`;
                        }
                    }
                }
            },
            cutout: '62%',
        }
    });
});

// ── Export PDF ──────────────────────────────────────────────────────
async function exporterPDF() {
    const btn   = document.getElementById('btn-pdf');
    const label = document.getElementById('pdf-label');
    const icon  = document.getElementById('pdf-icon');

    btn.disabled      = true;
    icon.textContent  = '⏳';
    label.textContent = 'Génération...';

    try {
        if (!window.html2canvas) await loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js');
        if (!window.jspdf)       await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');

        const { jsPDF } = window.jspdf;
        const pdf    = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
        const pageW  = 210;
        const pageH  = 297;
        const margin = 14;
        const teal   = [11, 122, 143];

        function sectionTitre(texte, posY) {
            pdf.setFontSize(12);
            pdf.setFont('helvetica', 'bold');
            pdf.setTextColor(...teal);
            pdf.text(texte, margin, posY);
            pdf.setDrawColor(...teal);
            pdf.setLineWidth(0.4);
            pdf.line(margin, posY + 1.5, pageW - margin, posY + 1.5);
            pdf.setTextColor(0, 0, 0);
        }

        // ── En-tête ──
        pdf.setFillColor(...teal);
        pdf.rect(0, 0, pageW, 30, 'F');
        pdf.setTextColor(255, 255, 255);
        pdf.setFontSize(17);
        pdf.setFont('helvetica', 'bold');
        pdf.text('Statistiques Programmes - MindGrow', margin, 13);
        pdf.setFontSize(9);
        pdf.setFont('helvetica', 'normal');
        const now = new Date().toLocaleDateString('fr-FR', {
            day: '2-digit', month: 'long', year: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });
        pdf.text('Genere le : ' + now, margin, 22);
        pdf.text('Rapport confidentiel — MindGrow', pageW - margin, 22, { align: 'right' });
        pdf.setTextColor(0, 0, 0);

        let y = 38;

        // ── KPIs ──
        sectionTitre('Indicateurs cles', y);
        y += 7;

        const kpis = [
            { id: 'kpi-total',  label: 'Total programmes'   },
            { id: 'kpi-cats',   label: 'Categories actives' },
            { id: 'kpi-images', label: 'Avec image'         },
            { id: 'kpi-videos', label: 'Avec video'         },
        ];

        const kpiW = (pageW - margin * 2 - 6) / 4;
        kpis.forEach((k, i) => {
            const x   = margin + i * (kpiW + 2);
            const val = document.getElementById(k.id)?.textContent?.trim() || '—';

            pdf.setFillColor(236, 254, 255);
            pdf.roundedRect(x, y, kpiW, 22, 3, 3, 'F');
            pdf.setDrawColor(...teal);
            pdf.setLineWidth(0.5);
            pdf.roundedRect(x, y, kpiW, 22, 3, 3, 'S');

            pdf.setFontSize(15);
            pdf.setFont('helvetica', 'bold');
            pdf.setTextColor(...teal);
            pdf.text(val, x + kpiW / 2, y + 10, { align: 'center', maxWidth: kpiW - 2 });

            pdf.setFontSize(7.5);
            pdf.setFont('helvetica', 'normal');
            pdf.setTextColor(71, 85, 105);
            pdf.text(k.label, x + kpiW / 2, y + 17, { align: 'center' });
        });
        y += 30;

        // ── Graphique programmes par catégorie ──
        sectionTitre('Programmes par categorie', y);
        y += 6;

        const canvasCat = document.getElementById('chartCategories');
        if (canvasCat) {
            const img = await html2canvas(canvasCat.closest('.chart-card'), {
                backgroundColor: isDark ? '#0f172a' : '#ffffff',
                scale: 2, useCORS: true, logging: false,
            });
            const imgW = pageW - margin * 2;
            const imgH = Math.min(Math.round((img.height * imgW) / img.width), 80);
            if (y + imgH > pageH - 15) { pdf.addPage(); y = 15; }
            pdf.addImage(img.toDataURL('image/jpeg', 0.95), 'JPEG', margin, y, imgW, imgH);
            pdf.setDrawColor(200, 220, 230); pdf.setLineWidth(0.3);
            pdf.rect(margin, y, imgW, imgH, 'S');
            y += imgH + 10;
        }

        // ── Graphiques côte à côte ──
        sectionTitre('Couverture medias', y);
        y += 6;

        const colW = (pageW - margin * 2 - 8) / 2;
        const charts2 = [
            { id: 'chartImages', titre: 'Couverture Images' },
            { id: 'chartVideos', titre: 'Couverture Videos' },
        ];
        let maxH = 0;
        const smImages = [];
        for (const ch of charts2) {
            const canvas = document.getElementById(ch.id);
            if (!canvas) { smImages.push(null); continue; }
            const img = await html2canvas(canvas.closest('.chart-card'), {
                backgroundColor: isDark ? '#0f172a' : '#ffffff',
                scale: 2, useCORS: true, logging: false,
            });
            const h = Math.min(Math.round((img.height * colW) / img.width), 80);
            maxH = Math.max(maxH, h);
            smImages.push({ data: img, w: colW, h, titre: ch.titre });
        }

        if (y + maxH + 10 > pageH - 15) { pdf.addPage(); y = 15; }
        smImages.forEach((sm, i) => {
            if (!sm) return;
            const x = margin + i * (colW + 8);
            pdf.setFontSize(9); pdf.setFont('helvetica', 'bold');
            pdf.setTextColor(30, 41, 59);
            pdf.text(sm.titre, x + colW / 2, y - 1, { align: 'center' });
            pdf.addImage(sm.data.toDataURL('image/jpeg', 0.95), 'JPEG', x, y, sm.w, sm.h);
            pdf.setDrawColor(200, 220, 230); pdf.setLineWidth(0.3);
            pdf.rect(x, y, sm.w, sm.h, 'S');
        });
        y += maxH + 12;

        // ── Pied de page ──
        const totalPages = pdf.internal.getNumberOfPages();
        for (let p = 1; p <= totalPages; p++) {
            pdf.setPage(p);
            pdf.setFillColor(245, 250, 252);
            pdf.rect(0, pageH - 12, pageW, 12, 'F');
            pdf.setDrawColor(...teal); pdf.setLineWidth(0.3);
            pdf.line(0, pageH - 12, pageW, pageH - 12);
            pdf.setFontSize(8); pdf.setFont('helvetica', 'normal');
            pdf.setTextColor(100, 116, 139);
            pdf.text('MindGrow — Rapport Statistiques Programmes', margin, pageH - 5);
            pdf.text('Page ' + p + ' / ' + totalPages, pageW - margin, pageH - 5, { align: 'right' });
        }

        const dateStr = new Date().toISOString().slice(0, 10);
        pdf.save('stats_programmes_mindgrow_' + dateStr + '.pdf');

    } catch(e) {
        console.error('[PDF] Erreur:', e);
        alert('Erreur lors de la generation du PDF : ' + e.message);
    } finally {
        btn.disabled      = false;
        icon.textContent  = '📄';
        label.textContent = 'Exporter PDF';
    }
}

function loadScript(src) {
    return new Promise((resolve, reject) => {
        const s = document.createElement('script');
        s.src = src; s.onload = resolve; s.onerror = reject;
        document.head.appendChild(s);
    });
}
</script>

{% endblock %}
