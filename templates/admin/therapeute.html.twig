<div id="deleteModal" class="delete-modal">
    <div class="delete-box">
        <h3>🗑️ Supprimer le thérapeute ?</h3>
        <p id="deleteText" style="color:#64748b; margin-top:8px;"></p>
        <div class="delete-actions">
            <button onclick="confirmDelete()" class="btn btn-danger">Oui, supprimer</button>
            <button onclick="closeDeleteModal()" class="btn" style="background:var(--bg3); color:var(--text2);">Annuler</button>
        </div>
    </div>
</div>

<script>
let deleteUrl = null;

function openDeleteModal(url, nom) {
    deleteUrl = url;
    document.getElementById('deleteModal').style.display = 'flex';
    document.getElementById('deleteText').innerText = 'Voulez-vous supprimer : ' + nom + ' ?';
}
function closeDeleteModal() {
    document.getElementById('deleteModal').style.display = 'none';
}
function confirmDelete() {
    window.location.href = deleteUrl;
}

// Auto-hide toast after 4s
document.addEventListener('DOMContentLoaded', function () {
    const toast = document.querySelector('.toast-success');
    if (toast) setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity 0.5s'; setTimeout(() => toast.remove(), 500); }, 4000);
});
</script>

