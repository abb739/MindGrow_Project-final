{% extends 'base.html.twig' %}
{% block title %}Réinitialiser le mot de passe{% endblock %}
{% block body %}
<div style="max-width:450px; margin:60px auto;">
    <div class="card">
        <h2 style="text-align:center; color:#0b7a8f; margin-bottom:20px;">🌱 Nouveau mot de passe</h2>
        {% if errors is defined and errors %}
            <div class="alert-error">
                <ul style="margin:0; padding-left:20px;">
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
        <form method="post" novalidate>
            <input type="hidden" name="token" value="{{ token }}">
            <div class="form-group">
                <label for="password">Nouveau mot de passe</label>
                <div class="pass-wrap">
                    <input type="password" id="password" name="password" placeholder="••••••••" autocomplete="new-password" required>
                    <button type="button" class="eye-btn" onclick="togglePass('password', this)" tabindex="-1">👁</button>
                </div>
                <span class="field-error" id="err-password"></span>
            </div>
            <div class="form-group">
                <label for="confirm">Confirmer le mot de passe</label>
                <div class="pass-wrap">
                    <input type="password" id="confirm" name="confirm" placeholder="••••••••" autocomplete="new-password" required>
                    <button type="button" class="eye-btn" onclick="togglePass('confirm', this)" tabindex="-1">👁</button>
                </div>
                <span class="field-error" id="err-confirm"></span>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%; padding:12px; font-size:16px; margin-top:8px;">Réinitialiser le mot de passe</button>
        </form>
        <p style="text-align:center; margin-top:15px; font-size:14px; color:#64748b;">
            <a href="{{ path('login') }}" style="color:#0b7a8f; font-weight:600;">Retour à la connexion</a>
        </p>
    </div>
</div>

<script>
function togglePass(inputId, btn) {
    const input = document.getElementById(inputId);
    if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
    } else {
        input.type = 'password';
        btn.textContent = '👁';
    }
}
</script>

<style>
  .field-error { color:#e53e3e; font-size:12px; margin-top:4px; display:block; min-height:16px; }
  .alert-error { background:#fed7d7; color:#c53030; padding:10px; border-radius:8px; margin-bottom:15px; }

  /* ── Inputs toujours lisibles ── */
  input[type="password"] {
    background: #ffffff !important;
    color: #1e293b !important;
    caret-color: #1e293b !important;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 15px;
    width: 100%;
  }
  input[type="password"]:focus {
    outline: none;
    border-color: #0b7a8f;
    box-shadow: 0 0 0 3px rgba(11, 122, 143, 0.1);
  }

  .pass-wrap {
    position: relative;
  }
  .eye-btn {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
  }

  .btn {
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s ease;
  }
  .btn-primary {
    background: #0b7a8f;
    color: white;
  }
  .btn-primary:hover {
    background: #0a6b7a;
  }

  .card {
    background: white;
    border-radius: 15px;
    padding: 30px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
</style>
{% endblock %}