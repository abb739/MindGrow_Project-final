{% extends 'base.html.twig' %}
{% block title %}Inscription{% endblock %}
{% block body %}
<div style="max-width:500px; margin:60px auto;">
    <div class="card">
        <h2 style="text-align:center; color:#0b7a8f; margin-bottom:24px;">🌱 Créer un compte</h2>

        {% if errors is defined and errors %}
            {% for error in errors %}
                <div class="alert-error">⚠️ {{ error }}</div>
            {% endfor %}
        {% endif %}

        {% if success is defined and success %}
            <div class="alert-success">✅ {{ success }}</div>
        {% endif %}
        {% if qrBase64 is defined %}
            <div class="qr-success-box" style="border:1px dashed #cbd5e1; padding:18px; margin-bottom:18px; border-radius:14px; background:#f8fafc; text-align:center;">
                <p style="margin:0 0 12px; font-weight:700; color:#0b7a8f;">QR Code de vos identifiants</p>
                <img src="data:image/svg+xml;base64,{{ qrBase64 }}" alt="QR Code des identifiants" style="max-width:240px; display:block; margin:0 auto;" />
                <p style="margin:12px 0 0; color:#475569; font-size:13px;">Scannez ce QR pour récupérer votre email et mot de passe plus tard.</p>
            </div>
        {% endif %}
        <form method="post" action="{{ path('register') }}" id="registerForm" novalidate>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div class="form-group">
                    <label for="nom">Nom * (min. 2 caract.)</label>
                    <input type="text" id="nom" name="nom" value="{{ nom ?? '' }}"
                           placeholder="Ben Ali" autocomplete="family-name">
                    <span class="field-error" id="err-nom"></span>
                </div>
                <div class="form-group">
                    <label for="prenom">Prénom * (min. 2 caract.)</label>
                    <input type="text" id="prenom" name="prenom" value="{{ prenom ?? '' }}"
                           placeholder="Ahmed" autocomplete="given-name">
                    <span class="field-error" id="err-prenom"></span>
                </div>
            </div>

            <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" value="{{ email ?? '' }}"
                       placeholder="ahmed@exemple.com" autocomplete="email">
                <span class="field-error" id="err-email"></span>
            </div>

            <div class="form-group">
                <label for="password">Mot de passe * (min. 6 caract.)</label>
                <div class="pass-wrap">
                    <input type="password" id="password" name="password"
                           placeholder="••••••••" autocomplete="new-password">
                    <button type="button" class="eye-btn" onclick="togglePass('password', this)" tabindex="-1">👁</button>
                </div>
                <span class="field-error" id="err-password"></span>
            </div>

            <div class="form-group">
                <label for="confirm">Confirmer le mot de passe *</label>
                <div class="pass-wrap">
                    <input type="password" id="confirm" name="confirm"
                           placeholder="••••••••" autocomplete="new-password">
                    <button type="button" class="eye-btn" onclick="togglePass('confirm', this)" tabindex="-1">👁</button>
                </div>
                <span class="field-error" id="err-confirm"></span>
            </div>


            <div class="form-group">
                <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
                <span class="field-error" id="err-captcha"></span>
            </div>
            <button type="submit" class="btn btn-primary"
                    style="width:100%; padding:14px; font-size:15px; margin-top:4px;">
                Créer mon compte →
            </button>
        </form>

        <p style="text-align:center; margin-top:20px; font-size:14px; color:#64748b;">
            Déjà un compte ? <a href="{{ path('login') }}" style="color:#0b7a8f; font-weight:600;">Se connecter</a>
        </p>
    </div>
</div>

<style>
  .field-error { color:#e53e3e; font-size:12px; margin-top:4px; display:block; min-height:16px; }

  /* ── Inputs toujours lisibles ── */
  input[type="text"],
  input[type="email"],
  input[type="password"] {
    background: #ffffff !important;
    color: #1e293b !important;
    caret-color: #1e293b !important;
    -webkit-text-fill-color: #1e293b !important;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 15px;
    width: 100%;
    box-sizing: border-box;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  input[type="text"]::placeholder,
  input[type="email"]::placeholder,
  input[type="password"]::placeholder {
    color: #94a3b8 !important;
    -webkit-text-fill-color: #94a3b8 !important;
    opacity: 1;
  }

  input[type="text"]:focus,
  input[type="email"]:focus,
  input[type="password"]:focus {
    outline: none;
    border-color: #0b7a8f;
    box-shadow: 0 0 0 3px rgba(11,122,143,0.12);
    background: #f0fdfb !important;
    color: #1e293b !important;
    -webkit-text-fill-color: #1e293b !important;
  }

  /* Autocomplete fix Chrome/Safari */
  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px #ffffff inset !important;
    -webkit-text-fill-color: #1e293b !important;
    caret-color: #1e293b !important;
  }

  input.input-invalid {
    border-color: #e53e3e !important;
    background: #fff5f5 !important;
    box-shadow: 0 0 0 3px rgba(229,62,62,0.10);
    -webkit-text-fill-color: #1e293b !important;
  }

  input.input-valid {
    border-color: #38a169 !important;
    box-shadow: 0 0 0 3px rgba(56,161,105,0.10);
  }

  .pass-wrap { position: relative; display: flex; align-items: center; }
  .pass-wrap input { padding-right: 42px !important; }
  .eye-btn {
    position: absolute; right: 10px;
    background: none; border: none; cursor: pointer;
    font-size: 16px; color: #94a3b8; padding: 4px;
    line-height: 1; transition: color 0.2s;
  }
  .eye-btn:hover { color: #0b7a8f; }
</style>

<script src="https://www.google.com/recaptcha/api.js" async defer></script>

<script>
function togglePass(id, btn) {
    const input = document.getElementById(id);
    input.type = input.type === 'password' ? 'text' : 'password';
    btn.textContent = input.type === 'password' ? '👁' : '🙈';
}



(function () {
    const form = document.getElementById('registerForm');

    function showError(inputId, spanId, msg) {
        const input = document.getElementById(inputId);
        const span  = document.getElementById(spanId);
        span.textContent = msg;
        if (input) { input.classList.add('input-invalid'); input.classList.remove('input-valid'); }
    }
    function showOk(inputId, spanId) {
        const input = document.getElementById(inputId);
        const span  = document.getElementById(spanId);
        span.textContent = '';
        if (input) { input.classList.remove('input-invalid'); input.classList.add('input-valid'); }
    }

    function validateNom() {
        const val = document.getElementById('nom').value.trim();
        if (!val) { showError('nom','err-nom','Le nom est obligatoire.'); return false; }
        if (val.length < 2) { showError('nom','err-nom','Le nom doit avoir au moins 2 caractères.'); return false; }
        showOk('nom','err-nom'); return true;
    }
    function validatePrenom() {
        const val = document.getElementById('prenom').value.trim();
        if (!val) { showError('prenom','err-prenom','Le prénom est obligatoire.'); return false; }
        if (val.length < 2) { showError('prenom','err-prenom','Le prénom doit avoir au moins 2 caractères.'); return false; }
        showOk('prenom','err-prenom'); return true;
    }
    function validateEmail() {
        const val = document.getElementById('email').value.trim();
        const re  = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!val) { showError('email','err-email',"L'email est obligatoire."); return false; }
        if (!re.test(val)) { showError('email','err-email','Format email invalide (ex: nom@domaine.com).'); return false; }
        showOk('email','err-email'); return true;
    }
    function validatePassword() {
        const val = document.getElementById('password').value;
        if (!val) { showError('password','err-password','Le mot de passe est obligatoire.'); return false; }
        if (val.length < 6) { showError('password','err-password','Le mot de passe doit avoir au moins 6 caractères.'); return false; }
        showOk('password','err-password'); return true;
    }
    function validateConfirm() {
        const pass    = document.getElementById('password').value;
        const confirm = document.getElementById('confirm').value;
        if (!confirm) { showError('confirm','err-confirm','Veuillez confirmer le mot de passe.'); return false; }
        if (pass !== confirm) { showError('confirm','err-confirm','Les mots de passe ne correspondent pas.'); return false; }
        showOk('confirm','err-confirm'); return true;
    }
    function validateCaptcha() {
        const captcha = document.querySelector('textarea[name="g-recaptcha-response"]');
        const value = captcha ? captcha.value.trim() : '';
        const span  = document.getElementById('err-captcha');
        if (!value) {
            if (span) { span.textContent = 'Veuillez cocher « Je ne suis pas un robot ». '; }
            return false;
        }
        if (span) { span.textContent = ''; }
        return true;
    }

    document.getElementById('nom').addEventListener('blur', validateNom);
    document.getElementById('prenom').addEventListener('blur', validatePrenom);
    document.getElementById('email').addEventListener('blur', validateEmail);
    document.getElementById('password').addEventListener('blur', validatePassword);
    document.getElementById('confirm').addEventListener('blur', validateConfirm);

    ['nom','prenom','email','password','confirm'].forEach(function(id) {
        document.getElementById(id).addEventListener('input', function() {
            if (this.classList.contains('input-invalid')) {
                ({ nom: validateNom, prenom: validatePrenom, email: validateEmail,
                   password: validatePassword, confirm: validateConfirm })[id]();
            }
        });
    });

    form.addEventListener('submit', function (e) {
        const ok = [validateNom(), validatePrenom(), validateEmail(),
                    validatePassword(), validateConfirm(), validateCaptcha()]
                   .every(Boolean);
        if (!ok) { e.preventDefault(); const first = form.querySelector('.input-invalid'); if (first) first.focus(); }
    });
})();
</script>
{% endblock %}