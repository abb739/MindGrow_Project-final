{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié{% endblock %}
{% block body %}
<div style="max-width:450px; margin:60px auto;">
    <div class="card">
        <h2 style="text-align:center; color:#0b7a8f; margin-bottom:20px;">🌱 Réinitialiser le mot de passe</h2>
        {% if error is defined and error %}
            <div class="alert-error">{{ error }}</div>
        {% endif %}
        {% if success is defined and success %}
            <div class="alert-success">{{ success }}</div>
        {% endif %}
        <form method="post" novalidate>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="votre@email.com" autocomplete="email" required>
                <span class="field-error" id="err-email"></span>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%; padding:12px; font-size:16px; margin-top:8px;">Envoyer le lien de réinitialisation</button>
        </form>
        <p style="text-align:center; margin-top:15px; font-size:14px; color:#64748b;">
            <a href="{{ path('login') }}" style="color:#0b7a8f; font-weight:600;">Retour à la connexion</a>
        </p>
    </div>
</div>

<style>
  .field-error { color:#e53e3e; font-size:12px; margin-top:4px; display:block; min-height:16px; }
  .alert-error { background:#fed7d7; color:#c53030; padding:10px; border-radius:8px; margin-bottom:15px; }
  .alert-success { background:#c6f6d5; color:#22543d; padding:10px; border-radius:8px; margin-bottom:15px; }

  /* ── Inputs toujours lisibles ── */
  input[type="email"] {
    background: #ffffff !important;
    color: #1e293b !important;
    caret-color: #1e293b !important;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 15px;
    width: 100%;
  }
  input[type="email"]:focus {
    outline: none;
    border-color: #0b7a8f;
    box-shadow: 0 0 0 3px rgba(11, 122, 143, 0.1);
  }

  .btn {
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s ease;
  }
  .btn-primary {
    background: #0b7a8f;
    color: white;
  }
  .btn-primary:hover {
    background: #0a6b7a;
  }

  .card {
    background: white;
    border-radius: 15px;
    padding: 30px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
</style>
{% endblock %}