<script>
const SYMBOLES_FALLBACK = { TND:'TND', EUR:'€', USD:'$', GBP:'£', SAR:'﷼', MAD:'MAD', CAD:'CA$', JPY:'¥', CHF:'CHF', AED:'AED' };
const DECIMALES_FALLBACK = { TND:3, EUR:2, USD:2, GBP:2, SAR:2, MAD:2, CAD:2, JPY:0, CHF:2, AED:2 };

let tauxData     = null;
let deviseActive = 'TND';

async function chargerTaux() {
    const loadIcon  = document.getElementById('devise-loading-icon');
    const indicator = document.getElementById('taux-indicator');
    if (loadIcon) loadIcon.style.display = 'inline';
    try {
        const res = await fetch('/api/currency/rates', {
            method: 'GET',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const json = await res.json();
        if (json.success && json.devises) {
            tauxData = json;
            if (indicator) {
                const isLive = json.source === 'live';
                indicator.dataset.source = json.source;
                indicator.style.color = isLive ? '#0b7a8f' : '#94a3b8';
                const updated = json.updated_at
                    ? new Date(json.updated_at).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' })
                    : '';
                indicator.title = isLive
                    ? '✅ Taux en temps réel • Mis à jour : ' + updated
                    : '⚠️ Taux approximatifs (hors ligne)';
            }
        } else {
            throw new Error('Réponse invalide');
        }
    } catch(e) {
        console.warn('[Devise] API interne indisponible, taux statiques utilisés.', e);
        tauxData = null;
    } finally {
        if (loadIcon) loadIcon.style.display = 'none';
        appliquerDevise(deviseActive);
    }
}

function getTaux(devise) {
    if (tauxData && tauxData.devises[devise]) return tauxData.devises[devise].taux;
    const fallback = { TND:1, EUR:0.2965, USD:0.32, GBP:0.254, SAR:1.20, MAD:3.21, CAD:0.439, JPY:47.85, CHF:0.289, AED:1.175 };
    return fallback[devise] || 1;
}

function getSymbole(devise) {
    if (tauxData && tauxData.devises[devise]) return tauxData.devises[devise].symbole;
    return SYMBOLES_FALLBACK[devise] || devise;
}

function getDecimales(devise) {
    if (tauxData && tauxData.devises[devise]) return tauxData.devises[devise].decimales;
    return DECIMALES_FALLBACK[devise] ?? 2;
}

function formaterMontant(valeur, devise) {
    const dec = getDecimales(devise);
    return parseFloat(valeur).toLocaleString('fr-FR', {
        minimumFractionDigits: dec,
        maximumFractionDigits: dec
    });
}

function appliquerDevise(devise) {
    deviseActive = devise;
    const taux    = getTaux(devise);
    const symbole = getSymbole(devise);

    document.querySelectorAll('.prix-converti').forEach(el => {
        el.textContent = formaterMontant(parseFloat(el.dataset.tnd) * taux, devise);
    });
    document.querySelectorAll('.mois-converti').forEach(el => {
        el.textContent = formaterMontant(parseFloat(el.dataset.tnd) * taux, devise);
    });
    document.querySelectorAll('.devise-label-card').forEach(el => {
        el.textContent = symbole;
    });

    const statRevenu   = document.getElementById('stat-revenu');
    const statDeviseEl = document.getElementById('stat-revenu-devise');
    if (statRevenu) {
        const tnd = parseFloat(statRevenu.dataset.tnd);
        statRevenu.firstChild.textContent = formaterMontant(tnd * taux, devise) + ' ';
    }
    if (statDeviseEl) statDeviseEl.textContent = symbole;

    const indicator = document.getElementById('taux-indicator');
    if (indicator) {
        if (devise === 'TND') {
            indicator.textContent = '';
        } else {
            const isLive = tauxData && tauxData.source === 'live';
            indicator.textContent = '1 TND ≈ ' + formaterMontant(taux, devise) + ' ' + symbole;
            indicator.style.color = isLive ? '#0b7a8f' : '#94a3b8';
        }
    }
    localStorage.setItem('devise', devise);
}

function changerDevise(devise) { appliquerDevise(devise); }

window.addEventListener('DOMContentLoaded', () => {
    const saved = localStorage.getItem('devise');
    if (saved) {
        deviseActive = saved;
        const sel = document.getElementById('deviseSelect');
        if (sel) sel.value = saved;
    }
    chargerTaux();
});
</script>

<script>
function dismissToast() {
    const t = document.getElementById('toastMsg');
    if (!t) return;
    t.style.animation = 'toastOut .35s ease forwards';
    setTimeout(() => t.remove(), 380);
}
window.addEventListener('DOMContentLoaded', () => {
    const t = document.getElementById('toastMsg');
    if (t) setTimeout(dismissToast, 4000);
});
</script>

